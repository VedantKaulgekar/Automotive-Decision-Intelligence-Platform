# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.env.*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── ML models (too large for Git) ─────────────────────────────────────────────
*.pkl
*.pickle
*.pt
*.pth
*.h5
*.joblib
*.onnx

# ── RAG index (rebuilt at runtime from documents) ─────────────────────────────
storage/rag_index/

# ── Generated reports (runtime output, not source) ────────────────────────────
storage/reports/
storage/scenarios/

# ── User-uploaded documents (not part of source) ──────────────────────────────
storage/user_docs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Build / dist ──────────────────────────────────────────────────────────────
build/
dist/
*.egg-info/
*.egg